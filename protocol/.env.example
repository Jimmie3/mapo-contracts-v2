# ============================================================
# Deployer Private Keys
# ============================================================
# EVM mainnet deployer key (used for Mapo, Eth, Bsc, Base, Arb, Op, Uni, Pol, Xlayer)
PRIVATE_KEY=
# EVM testnet deployer key (used for Mapo_test, Eth_test, Bsc_test)
TESTNET_PRIVATE_KEY=
# Tron deployer key (no 0x prefix)
TRON_PRIVATE_KEY=

# ============================================================
# Tron RPC
# ============================================================
# TronWeb full host URL (not JSON-RPC path). Used by TronClient.
# Hardhat config appends /jsonrpc for its own use, TronClient strips it.
TRON_RPC_URL=https://api.trongrid.io/jsonrpc
TRON_TEST_RPC_URL=https://nile.trongrid.io/jsonrpc

# ============================================================
# Deployment
# ============================================================
# CREATE2 salt for deterministic Gateway/Relay deployment via factory
GATEWAY_SALT=
# Deployment environment (REQUIRED): "test", "prod", or "main"
# Determines deploy.json key and config directory
# test -> deploy.json: test.Bsc, configs: testnet/
# prod -> deploy.json: prod.Bsc, configs: prod/
# main -> deploy.json: main.Bsc, configs: mainnet/
NETWORK_ENV=

# ============================================================
# Contract Verification
# ============================================================
# Etherscan API key — works across all EVM chains via v2 API
# Not needed for Mapo (Blockscout) or Tron (TronScan, no key required)
ETHERSCAN_API_KEY=
